rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role (admin|student), displayName
    //
    // Collection: knowledge
    // Fields: title, subject, summary, image_url, example, keywords, createdAt, updatedAt
    //
    // Collection: subjects
    // Fields: name, icon
    //
    // Collection: bookmarks
    // Fields: userId, knowledgeId, createdAt
    //
    // Collection: feedback
    // Fields: userId, knowledgeId, content, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == "anhvinhktu2020@gmail.com"
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidKnowledge(data) {
      return data.keys().hasAll(['title', 'subject', 'summary', 'keywords']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.subject is string &&
             data.summary is string && data.summary.size() < 10000 &&
             data.keywords is list && data.keywords.size() < 20;
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['userId', 'knowledgeId']) &&
             data.userId == request.auth.uid &&
             data.knowledgeId is string;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'knowledgeId', 'content']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() < 1000;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /knowledge/{knowledgeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
